# ───────────────────────────────────────────────────────────────
#  LENA — Bot de WhatsApp del Dr. César Carlos Coronado (cirugía plástica)
#  Copia este archivo como .env y completa los valores reales.
# ───────────────────────────────────────────────────────────────

# Puerto del servidor (en EasyPanel usa el que te asigne; local 3000)
PORT=3000

# ── OpenAI (GPT-4o para el cerebro + Whisper para transcribir audios) ──
OPENAI_API_KEY=sk-...

# ── Supabase (base de datos: memoria de chats + leads) ──
# Crea un proyecto nuevo en supabase.com para Lena (NO reuses el de Eli).
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_...

# ── Evolution API (puente con WhatsApp) ──
# Crea una INSTANCIA NUEVA para el número de WhatsApp de Lena y escanéala por QR.
EVOLUTION_API_URL=https://tu-evolution-api.easypanel.host
EVOLUTION_API_KEY=tu-api-key
EVOLUTION_INSTANCE=lena

# ── Coordinadora (Tati) ──
# Número de WhatsApp de Tati, sin + ni espacios (ej: 51987654321).
# El código enruta a ASISTENTE_LIMA si la ciudad del lead es "Lima", y a
# ASISTENTE_PIURA en cualquier otro caso (Piura, Chiclayo o virtual).
# Como la coordinadora es siempre Tati, pon SU MISMO número en ambos.
ASISTENTE_PIURA=51XXXXXXXXX
ASISTENTE_LIMA=51XXXXXXXXX

# ── URL pública del bot (para imágenes de followup, si las usas en el futuro) ──
BOT_URL=https://lena.tudominio.com

# ── Modos de prueba del followup (opcionales) ──
# FOLLOWUP_TEST_MODE=true  → delays en segundos (prueba la secuencia en minutos)
# FOLLOWUP_DEMO_MODE=true  → un solo mensaje a los 2 min
FOLLOWUP_TEST_MODE=false
FOLLOWUP_DEMO_MODE=false
